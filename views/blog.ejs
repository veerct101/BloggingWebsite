<!DOCTYPE html>
<html lang="en">
<%- include('./partials/head.ejs') %>

    <body>
        <%- include('./partials/nav.ejs') %>

            <div class="container mt-3">

                <div class="mt-3 border-3">
                    <h2 class="card-title">
                        <%=blog.title%>
                    </h2>
                    <img src="<%= blog.coverImageURL %>" width="600px" class="mt-3">
                    <div class="card-body">

                        <pre style="color: rgb(28, 39, 70); font-size:17px" class="mt-3"><%= blog.body %></pre>
                    </div>
                </div>
                <div class="container mt-5">
                    <h6><img src="<%= blog.createdBy.profileImage %>" width="40px" /><span class="ml-3">&nbsp;<%=
                                blog.createdBy.fullName %></span>
                    </h6>
                </div>

            </div>


            <div class="container mt-5">
                <h5>Comments(<%=allComment.length %>)</h5>
                <% if (locals.user) { %>

                    <form method="post" action="/blog/comment/<%= blog._id %>">
                        <div class="mb-1 mt-2">
                            <input type="text" class="form-control mb-1" name="content"
                                placeholder="Enter your comments">
                            <button type="submit" class="btn btn-primary">Add</button>
                        </div>
                    </form>
                    <% } %>
            </div>

            <div class="container mb-1 mt-4 border border-2 rounded-2">
                <% allComment.forEach(comment=> { %>
                    <span>
                        <img src="<%= comment.createdBy.profileImage %>" width="30" class="me-2 rounded-circle" />
                        <b>
                            <%= comment.createdBy.fullName %>
                        </b>
                        
                        <pre>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<%= comment.content %></pre>

                    </span>
                    <br>
                    <% }) %>
            </div>


            <%- include('./partials/script.ejs') %>
    </body>

</html>